# Copy to .env and fill in real values.

# WebAuthn Relying Party config.
# RP_ID must equal the *frontend* hostname (no scheme, no port, no path).
# EXPECTED_ORIGIN must equal the full origin the browser sees (scheme + host + port).
# Local dev:
RP_ID=localhost
RP_NAME=PassKey
EXPECTED_ORIGIN=http://localhost:5173
# Production example (Vercel + Render):
#   RP_ID=passkey-frontend.vercel.app
#   EXPECTED_ORIGIN=https://passkey-frontend.vercel.app

# Database.
# Local: SQLite. Prod: a Postgres URL (Render injects DATABASE_URL automatically when linked).
DB_URL=sqlite+aiosqlite:///./passkey.db

# 32 random bytes, base64-encoded. Generate with: openssl rand -base64 32
VAULT_KEY=REPLACE_ME_32_BYTES_BASE64

# Secret for signing session cookies. Generate with: openssl rand -hex 32
SESSION_SECRET=REPLACE_ME_HEX_64

# Session TTL in seconds (24h default)
SESSION_TTL_SECONDS=86400

# Cross-origin cookie settings.
# Local dev: false / lax. Production (frontend and backend on different domains):
#   SECURE_COOKIES=true
#   COOKIE_SAMESITE=none
SECURE_COOKIES=false
COOKIE_SAMESITE=lax
