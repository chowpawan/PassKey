# Copy to .env and fill in real values.

# WebAuthn Relying Party config (must match the frontend origin the browser sees)
RP_ID=localhost
RP_NAME=PassKey
EXPECTED_ORIGIN=http://localhost:5173

# Database
DB_URL=sqlite+aiosqlite:///./passkey.db

# 32 random bytes, base64-encoded. Generate with: openssl rand -base64 32
VAULT_KEY=REPLACE_ME_32_BYTES_BASE64

# Secret for signing session cookies. Generate with: openssl rand -hex 32
SESSION_SECRET=REPLACE_ME_HEX_64

# Session TTL in seconds (24h default)
SESSION_TTL_SECONDS=86400
